generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── UTILISATEURS ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("RH") // RH | RESPONSABLE | ADMIN | EMPLOYE
  permissions  String   @default("[]")  // JSON array de clés de modules
  employeId    String?  @unique          // renseigné uniquement pour rôle EMPLOYE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employe          Employe?               @relation(fields: [employeId], references: [id], onDelete: SetNull)
  demandesInitiees DossierDisciplinaire[] @relation("DossierInitiateur")
  notifications    Notification[]
  documentsUploades Document[]            @relation("DocumentUpload")
}

// ─── EMPLOYÉS ──────────────────────────────────────────────────────────────

model Employe {
  id               String    @id @default(cuid())
  matricule        String    @unique
  prenom           String
  nom              String
  email            String?
  telephone        String?
  dateNaissance    DateTime?
  lieuNaissance    String?
  adresse          String?
  nationalite      String?
  numeroCni        String?
  poste            String
  departement      String?
  typeContrat      String
  dateEmbauche     DateTime
  dateFinContrat   DateTime?
  periodeEssai     Boolean   @default(false)
  dateDebutEssai   DateTime?
  dateFinEssai     DateTime?
  salaireBase           Float
  statut                String    @default("ACTIF")
  photoUrl              String?
  notes                 String?
  soldeCongesAnnuels    Int       @default(30)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  faceDescriptor         String?   // JSON : Float32Array[128] sérialisé pour face-api.js
  managerId              String?   // référence vers un autre Employe (organigramme)
  contactUrgenceNom      String?
  contactUrgenceTel      String?
  zktecoPin              String?   @unique  // PIN enregistré sur le terminal ZKTeco (ex: "1234")

  conges                 Conge[]
  dossiersDisciplinaires DossierDisciplinaire[]
  historiqueSalaires     HistoriqueSalaire[]
  documents              Document[]
  evaluations            Evaluation[]
  presences              Presence[]
  affectationsShift      AffectationShift[]
  pointages              Pointage[]
  utilisateur            User?
  formations             ParticipationFormation[]
  avances                AvanceSalaire[]
}

// ─── CONGÉS ────────────────────────────────────────────────────────────────

model Conge {
  id          String   @id @default(cuid())
  employeId   String
  type        String
  dateDebut   DateTime
  dateFin     DateTime
  nbJours     Int
  motif       String?
  statut      String   @default("EN_ATTENTE")
  commentaire String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)
}

// ─── MODULE DISCIPLINAIRE ──────────────────────────────────────────────────
//
// Workflow :
//   INITIE           → Responsable a soumis la demande
//   EN_ATTENTE_DOC   → RH doit générer et uploader le document
//   DOCUMENT_PRET    → RH a uploadé le document, responsable peut télécharger
//   ENVOYE_EMPLOYE   → Responsable a remis le document à l'employé
//   EN_ATTENTE_REP   → Attente de la réponse de l'employé (délai en cours)
//   REPONSE_RECUE    → Responsable a uploadé la réponse scannée
//   REPONSE_EVALUEE  → RH a évalué la réponse (dans / hors délai)
//   SANCTION_AUTO    → Sanction auto appliquée (hors délai ou sans réponse)
//   CLOS             → Dossier clôturé

model DossierDisciplinaire {
  id          String   @id @default(cuid())
  employeId   String
  type        String   // DEMANDE_EXPLICATION | AVERTISSEMENT | BLAME | MISE_EN_DEMEURE | MISE_A_PIED | LICENCIEMENT
  date        DateTime
  motif       String
  description String
  statut      String   @default("INITIE")
  sanctions   String?
  suites      String?

  // ── Phase 1 : contexte ────────────────────────────────────────────────────
  categoriesFaits   String?  // RETARD | ABSENCE | INSUBORDINATION | FAUTE_PRO | COMPORTEMENT | AUTRE
  niveauGravite     String?  // FAIBLE | MODERE | ELEVE | CRITIQUE
  temoins           String?  // noms des témoins (texte libre)

  // ── Phase 2 : workflow de base ────────────────────────────────────────────
  initiePar             String?
  delaiReponseJours     Int      @default(5)
  dateEnvoiDocument     DateTime?
  dateEnvoiEmploye      DateTime?
  dateReponseAttendue   DateTime?
  dateReponseReelle     DateTime?
  statutReponse         String?   // EN_ATTENTE | DANS_DELAI | HORS_DELAI
  sanctionAutoAppliquee Boolean  @default(false)
  sanctionAutoRef       String?

  // ── Phase 3 : accusé de réception ─────────────────────────────────────────
  modeRemise              String?   // EN_MAIN_PROPRE | COURRIER_RECOMMANDE | EMAIL
  dateRemiseEffective     DateTime?
  accuseReceptionUrl      String?   // filename dans uploads/
  refusReception          Boolean   @default(false)
  refusReceptionNote      String?

  // ── Phase 4 : analyse RH ──────────────────────────────────────────────────
  appreciationRH           String?
  decisionFinale           String?   // ACCEPTEE | PARTIELLEMENT_ACCEPTEE | REJETEE
  sanctionRetenue          String?
  documentDecisionUrl      String?   // filename dans uploads/
  dateNotificationDecision DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employe       Employe       @relation(fields: [employeId], references: [id], onDelete: Cascade)
  initiateur    User?         @relation("DossierInitiateur", fields: [initiePar], references: [id])
  documents     Document[]
  notifications Notification[]
  auditLogs     AuditLog[]
  notesInternes NoteInterne[]
}

// ─── JOURNAL D'AUDIT ───────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  dossierId   String
  auteurId    String?
  auteurNom   String?
  type        String   // CREATION | DOC_RH | TRANSMISSION | ACCUSE_RECU | REFUS_RECEPTION | REPONSE | ANALYSE | DECISION | CLOTURE | NOTE | SANCTION_AUTO
  description String
  metadata    String?  // JSON sérialisé (infos supplémentaires)
  createdAt   DateTime @default(now())

  dossier DossierDisciplinaire @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

// ─── NOTES INTERNES RH ────────────────────────────────────────────────────

model NoteInterne {
  id        String   @id @default(cuid())
  dossierId String
  auteurId  String
  auteurNom String
  contenu   String
  createdAt DateTime @default(now())

  dossier DossierDisciplinaire @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

// ─── DOCUMENTS (upload RH + scan réponse) ─────────────────────────────────

model Document {
  id                     String   @id @default(cuid())
  nom                    String
  type                   String   // DOCUMENT_RH | REPONSE_EMPLOYE | AUTRE
  url                    String   // chemin fichier : uploads/disciplinaire/<filename>
  taille                 Int?     // octets
  mimeType               String?
  uploadeParId           String?  // userId
  employeId              String?
  dossierDisciplinaireId String?
  createdAt              DateTime @default(now())

  uploadePar           User?                 @relation("DocumentUpload", fields: [uploadeParId], references: [id])
  employe              Employe?              @relation(fields: [employeId], references: [id], onDelete: Cascade)
  dossierDisciplinaire DossierDisciplinaire? @relation(fields: [dossierDisciplinaireId], references: [id], onDelete: Cascade)
}

// ─── NOTIFICATIONS IN-APP ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // DEMANDE_INITIE | DOCUMENT_PRET | ENVOYE_EMPLOYE | REPONSE_RECUE | SANCTION_AUTO | DELAI_DEPASSE
  titre     String
  message   String
  lu        Boolean  @default(false)
  dossierId String?
  createdAt DateTime @default(now())

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dossier DossierDisciplinaire? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
}

// ─── SALAIRES ──────────────────────────────────────────────────────────────

model HistoriqueSalaire {
  id           String    @id @default(cuid())
  employeId    String
  mois         Int
  annee        Int
  salaireBase  Float
  primes       Float     @default(0)
  retenues     Float     @default(0)   // autres retenues manuelles (avances, absences…)
  // ── Cotisations Cameroun (calculées automatiquement) ──
  cnpsSalarie  Float     @default(0)   // 4.2% du brut plafonné à 750 000 FCFA
  irpp         Float     @default(0)   // IRPP mensuel (barème progressif)
  cac          Float     @default(0)   // 10% de l'IRPP (Centimes Add. Communaux)
  rav          Float     @default(625) // Redevance Audiovisuelle mensuelle
  // ── Heures supplémentaires (Code du Travail camerounais) ──
  heuresSupplementaires Float @default(0)   // nb heures sup travaillées
  montantHS             Float @default(0)   // montant brut calculé des HS
  // ── Charges patronales (informatif) ──
  cnpsPatronal Float     @default(0)   // 13.2% du brut plafonné (3.7+7+2.5)
  brutImposable Float    @default(0)   // Brut = base + primes + HS
  netAPayer    Float
  avanceDeduite Float    @default(0)   // avance sur salaire déduite ce mois
  statut       String    @default("EN_ATTENTE")
  datePaiement DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)
}

// ─── AVANCES SUR SALAIRE ───────────────────────────────────────────────────

model AvanceSalaire {
  id         String   @id @default(cuid())
  employeId  String
  montant    Float
  date       DateTime @default(now())
  motif      String?
  statut     String   @default("EN_ATTENTE") // EN_ATTENTE | VALIDEE | DEDUITE
  bulletinId String?  // id du HistoriqueSalaire sur lequel elle a été déduite
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)
}

// ─── ANNONCES INTERNES ────────────────────────────────────────────────────

model Annonce {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  type      String   @default("INFO") // INFO | IMPORTANT | URGENT
  auteur    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ÉVALUATIONS DE PERFORMANCE ────────────────────────────────────────────

model Evaluation {
  id              String   @id @default(cuid())
  employeId       String
  typeEvaluation  String   @default("ANNUELLE") // ANNUELLE | SEMESTRIELLE | TRIMESTRIELLE | PERIODE_ESSAI | PONCTUELLE
  periode         String
  dateEval        DateTime
  evaluateur      String
  scoreGlobal     Float
  noteAutoEmploye Float?   // score auto-évaluation soumis par l'employé
  commentaire     String?
  recommandation  String?  // PROMOTION | AUGMENTATION | FORMATION | MAINTIEN | VIGILANCE
  statut          String   @default("BROUILLON") // BROUILLON | FINALISE | PUBLIE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employe   Employe               @relation(fields: [employeId], references: [id], onDelete: Cascade)
  notes     NoteEvaluation[]
  objectifs ObjectifEvaluation[]
  actions   ActionDeveloppement[]
}

model NoteEvaluation {
  id           String  @id @default(cuid())
  evaluationId String
  critere      String
  note         Int
  commentaire  String?
  poids        Float   @default(1.0) // pondération du critère

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}

model ObjectifEvaluation {
  id           String   @id @default(cuid())
  evaluationId String
  titre        String
  description  String?
  resultat     String?  // commentaire sur le résultat obtenu
  atteint      String   @default("EN_COURS") // ATTEINT | PARTIEL | NON_ATTEINT | EN_COURS
  createdAt    DateTime @default(now())

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}

model ActionDeveloppement {
  id           String    @id @default(cuid())
  evaluationId String
  titre        String
  type         String    @default("FORMATION") // FORMATION | COACHING | PROJET | RESPONSABILITE | AUTRE
  description  String?
  echeance     DateTime?
  statut       String    @default("PLANIFIE") // PLANIFIE | EN_COURS | REALISE | ANNULE
  createdAt    DateTime  @default(now())

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}

// ─── SHIFTS & HORAIRES ─────────────────────────────────────────────────────

model Shift {
  id          String   @id @default(cuid())
  nom         String
  heureDebut  String
  heureFin    String
  couleur     String   @default("#3b82f6")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  affectations AffectationShift[]
}

model AffectationShift {
  id        String   @id @default(cuid())
  employeId String
  shiftId   String
  dateDebut DateTime
  dateFin   DateTime
  createdAt DateTime @default(now())

  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)
  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model Presence {
  id                String   @id @default(cuid())
  employeId         String
  date              DateTime
  heureArrivee      String?
  heureDepart       String?
  heuresTravaillees Float?
  minutesRetard     Int      @default(0)
  statut            String   @default("PRESENT")
  notes             String?
  // ── Saisie manuelle (panne de courant, etc.) ──────────────────────────────
  saisieManuelle    Boolean  @default(false)
  statutValidation  String   @default("VALIDEE")  // VALIDEE | EN_ATTENTE | REJETEE
  saisieParNom      String?  // nom de la personne ayant saisi
  motifManuel       String?  // motif de la saisie manuelle
  createdAt         DateTime @default(now())

  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)
}

// ─── MODULE POINTAGE QR + FACIAL + ZKTECO ─────────────────────────────────

model ZktecoDevice {
  id           String    @id @default(cuid())
  serialNumber String    @unique  // Numéro de série du terminal (SN)
  nom          String    @default("Terminal ZKTeco")
  lieu         String?             // ex: "Entrée principale", "Atelier B"
  actif        Boolean   @default(true)
  lastSyncAt   DateTime?           // Dernière communication reçue
  totalPushes  Int       @default(0)
  createdAt    DateTime  @default(now())

  pointages    Pointage[]
}

model Atelier {
  id        String   @id @default(cuid())
  nom       String
  code      String   @unique  // ex: "ATELIER_A", "BUREAU_RH" — contenu du QR code
  couleur   String   @default("#3b82f6")
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pointages Pointage[]
}

model Pointage {
  id            String    @id @default(cuid())
  employeId     String
  atelierId     String?   // null si l'employé n'a pas encore scanné le 2e QR
  dateEntree    DateTime  @default(now())
  dateSortie    DateTime?
  faceVerified  Boolean   @default(false)
  faceScore     Float?    // distance euclidienne face-api.js (plus petit = meilleure correspondance)
  statut        String    @default("EN_ATTENTE")
  // EN_ATTENTE   → arrivée scannée, en attente du QR atelier
  // CONFIRME     → QR atelier + face OK / ZKTeco empreinte OK
  // FACE_ECHEC   → reconnaissance faciale échouée
  // MANUEL       → saisi ou corrigé manuellement par RH
  // SORTI        → départ enregistré
  verifyMethod  String?   // "empreinte" | "carte" | "face" | "mdp" | "qr_face"
  source        String    @default("QR")  // "QR" | "ZKTECO" | "MANUEL"
  zktecoDeviceId String?
  noteRH        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employe       Employe       @relation(fields: [employeId], references: [id], onDelete: Cascade)
  atelier       Atelier?      @relation(fields: [atelierId], references: [id], onDelete: SetNull)
  zktecoDevice  ZktecoDevice? @relation(fields: [zktecoDeviceId], references: [id], onDelete: SetNull)
}

// ─── HISTORIQUE DES INTERACTIONS ──────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?  // null pour les actions système ou pointage sans login
  userName    String?
  userRole    String?
  action      String   // CREATE | UPDATE | DELETE | APPROVE | REJECT | LOGIN | POINTAGE_ENTREE | POINTAGE_CONFIRME | UPLOAD | ENROLL_FACE
  module      String   // EMPLOYES | CONGES | SALAIRES | EVALUATIONS | DISCIPLINAIRE | POINTAGE | HORAIRES | AUTH
  description String
  entityId    String?  // id de la ressource affectée
  entityType  String?  // "Employe" | "Conge" | "Salaire" | "Evaluation" | "Pointage" | etc.
  metadata    String?  // JSON sérialisé (données supplémentaires)
  createdAt   DateTime @default(now())
}

// ─── PARAMÈTRES GLOBAUX ────────────────────────────────────────────────────

model Parametre {
  id        String   @id @default(cuid())
  cle       String   @unique
  valeur    String
  updatedAt DateTime @updatedAt
}

// ─── MODULE RECRUTEMENT ────────────────────────────────────────────────────

model Offre {
  id            String   @id @default(cuid())
  titre         String
  departement   String?
  typeContrat   String   @default("CDI")
  localisation  String?
  description   String?
  salaireFourchette String?
  statut        String   @default("OUVERTE")  // OUVERTE | POURVUE | SUSPENDUE | FERMEE
  priorite      String   @default("NORMALE")  // BASSE | NORMALE | HAUTE | URGENTE
  dateOuverture DateTime @default(now())
  dateCloture   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  candidats Candidat[]
}

model Candidat {
  id          String   @id @default(cuid())
  offreId     String
  prenom      String
  nom         String
  email       String?
  telephone   String?
  source      String?  // LINKEDIN | INDEED | RECOMMANDATION | SITE_WEB | AUTRE
  cvUrl       String?
  lettreUrl   String?
  statut      String   @default("RECU")  // RECU | QUALIFIE | ENTRETIEN | TEST | OFFRE | EMBAUCHE | REFUSE | ABANDONNE
  noteGlobale Float?
  commentaire String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offre      Offre      @relation(fields: [offreId], references: [id], onDelete: Cascade)
  entretiens Entretien[]
}

model Entretien {
  id          String   @id @default(cuid())
  candidatId  String
  type        String   @default("TELEPHONIQUE")  // TELEPHONIQUE | VISIO | PRESENTIEL | TECHNIQUE
  date        DateTime
  dureeMin    Int?
  intervieweur String?
  note        Float?
  commentaire String?
  statut      String   @default("PLANIFIE")  // PLANIFIE | REALISE | ANNULE | REPORTE
  createdAt   DateTime @default(now())

  candidat Candidat @relation(fields: [candidatId], references: [id], onDelete: Cascade)
}

// ─── MODULE FORMATION ─────────────────────────────────────────────────────

model Formation {
  id            String   @id @default(cuid())
  titre         String
  type          String   @default("INTERNE")  // INTERNE | EXTERNE | E_LEARNING | CERTIFICATION
  organisme     String?
  description   String?
  dureeHeures   Float?
  cout          Float?
  dateDebut     DateTime?
  dateFin       DateTime?
  lieu          String?
  statut        String   @default("PLANIFIE")  // PLANIFIE | EN_COURS | TERMINE | ANNULE
  maxParticipants Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participations ParticipationFormation[]
}

model ParticipationFormation {
  id          String   @id @default(cuid())
  formationId String
  employeId   String
  statut      String   @default("INSCRIT")  // INSCRIT | PRESENT | ABSENT | VALIDE | ECHEC
  note        Float?
  certificat  Boolean  @default(false)
  commentaire String?
  createdAt   DateTime @default(now())

  formation Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  employe   Employe   @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@unique([formationId, employeId])
}
